# Copy to .env and fill in. Supabase → Project Settings → API.
# The SERVICE ROLE key is secret and bypasses RLS — never expose it to the
# browser or commit it. In GitHub Actions, set these as repository secrets.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Telegram alerts (optional). Create a bot via @BotFather for the token, then
# `npm run telegram:chatid` to find your chat id. Leave blank to disable alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
